<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:viewModels="clr-namespace:Mogri.Interfaces.ViewModels.Pages"
                xmlns:itemViewModels="clr-namespace:Mogri.Interfaces.ViewModels"
                xmlns:views="clr-namespace:Mogri.Views;assembly=Mogri"
                x:Class="Mogri.Views.LicensesPage"
                Background="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource CadetDark}}"
                LightStatusBarColor="{StaticResource Secondary}"
                DarkStatusBarColor="{StaticResource CadetDark}"
                StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}"
                x:DataType="viewModels:ILicensesPageViewModel"
                Shell.PresentationMode="ModalAnimated"
                Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto" Padding="0,16">

        <Label Grid.Row="0" 
               Text="Open Source Licenses" 
               FontFamily="ComfortaaBold" 
               FontSize="24" 
               TextColor="{AppThemeBinding Light={StaticResource NeutralDarkGray}, Dark={StaticResource Secondary}}" 
               HorizontalOptions="Center" 
               Margin="0,16,0,24" />

        <CollectionView Grid.Row="1" ItemsSource="{Binding Licenses}" HorizontalOptions="Fill" Margin="0,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="itemViewModels:ILicenseItemViewModel">
                    <Border Padding="12" Margin="12,0,12,12" Background="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Black}}" Stroke="{StaticResource Cadet}" StrokeShape="RoundRectangle 8">
                        <StackLayout Spacing="8">
                            <StackLayout.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleExpandedCommand}" />
                            </StackLayout.GestureRecognizers>
                            
                            <Label Text="{Binding Name}" FontFamily="ComfortaaBold" FontSize="18" TextColor="{StaticResource Primary}" />
                            <Label Text="{Binding LicenseType}" FontFamily="ComfortaaRegular" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource NeutralDarkGray}, Dark={StaticResource Secondary}}" />
                            <Label Text="{Binding Description}" FontFamily="ComfortaaRegular" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource NeutralDarkGray}, Dark={StaticResource Secondary}}" />
                            
                            <Label Text="{Binding LicenseText}" 
                                   FontFamily="OpenSansRegular" 
                                   FontSize="12" 
                                   LineBreakMode="WordWrap"
                                   IsVisible="{Binding IsExpanded}" 
                                   TextColor="{AppThemeBinding Light={StaticResource NeutralDarkGray}, Dark={StaticResource Secondary}}" 
                                   Margin="0,12,0,0" />

                            <Label Text="{Binding Url}" 
                                   FontFamily="OpenSansRegular" 
                                   FontSize="12" 
                                   TextColor="{StaticResource Primary}"
                                   TextDecorations="Underline"
                                   IsVisible="{Binding IsExpanded}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenUrlCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </StackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ImageButton Grid.Row="2" ToolTipProperties.Text="Close" HorizontalOptions="Center" Command="{Binding BackButtonCommand}" Margin="0,16,0,0" WidthRequest="40" Aspect="Center">
            <ImageButton.Source>
                <FontImageSource Glyph="&#xe5cd;" FontFamily="{StaticResource IconFontRegular}" Size="30" Color="{StaticResource Primary}" />
            </ImageButton.Source>
        </ImageButton>
        
    </Grid>
</views:BasePage>
