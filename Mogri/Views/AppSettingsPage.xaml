<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:pages="clr-namespace:Mogri.Interfaces.ViewModels.Pages"
                xmlns:viewModels="clr-namespace:Mogri.Interfaces.ViewModels"
                xmlns:views="clr-namespace:Mogri.Views"
                x:Class="Mogri.Views.AppSettingsPage"
                x:DataType="pages:IAppSettingsPageViewModel"
                Shell.PresentationMode="Animated"
                Shell.NavBarIsVisible="True"
                Shell.TabBarIsVisible="False">
    <Shell.TitleView>
        <Label Text="Application Settings" Style="{StaticResource LabelTitleView}" />
    </Shell.TitleView>

    <views:BasePage.ToolbarItems>
        <ToolbarItem Command="{Binding ResetValuesCommand}"
                     Text="Reset">
            <ToolbarItem.IconImageSource>
                <FontImageSource Glyph="&#xe872;" FontFamily="{StaticResource IconFontRegular}" Size="24" Color="{OnPlatform Android={StaticResource MutedPeach}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </views:BasePage.ToolbarItems>

    <Grid RowDefinitions="*,auto"
          Padding="0"
          Margin="0">
        <ScrollView Grid.Row="0" Orientation="Vertical">
            <Grid x:Name="MainGrid"
              Padding="30"
              RowDefinitions="auto, auto, auto, auto, auto"
              RowSpacing="10"
              ColumnSpacing="16"
              ColumnDefinitions="32,auto,*"
              HorizontalOptions="Fill">

                <Image Grid.Row="0" Grid.Column="0" WidthRequest="32">
                    <Image.Source>
                        <FontImageSource Glyph="&#xeb3f;" FontFamily="{StaticResource IconFontRegular}" Size="32" Color="{StaticResource Tertiary}" />
                    </Image.Source>
                </Image>
                <Label Grid.Row="0" Grid.Column="1" Text="Backend:" VerticalTextAlignment="Center" Style="{StaticResource LabelHeader}" />
                <Picker Grid.Row="0" Grid.Column="2" ItemsSource="{Binding AvailableBackends}" SelectedItem="{Binding SelectedBackend}" HorizontalOptions="End" />

                <!-- Server URL Section -->
                <Image Grid.Row="1" Grid.Column="0" WidthRequest="32" IsVisible="{Binding IsServerUrlVisible}">
                    <Image.Source>
                        <FontImageSource Glyph="&#xe30a;" FontFamily="{StaticResource IconFontRegular}" Size="32" Color="{StaticResource Tertiary}" />
                    </Image.Source>
                </Image>
                <Label Grid.Row="1" Grid.Column="1" Text="Server URL:" VerticalTextAlignment="Center" Style="{StaticResource LabelHeader}" IsVisible="{Binding IsServerUrlVisible}"/>
                <Entry Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Text="{Binding ServerUrl}" Placeholder="Ex. http://192.168.0.1" Keyboard="Url" HorizontalOptions="Fill" IsVisible="{Binding IsServerUrlVisible}" />

                <!-- ComfyUI API Key Section -->
                <Image Grid.Row="3" Grid.Column="0" WidthRequest="32" IsVisible="{Binding IsComfyUiCloudSelected}">
                    <Image.Source>
                        <FontImageSource Glyph="&#xe897;" FontFamily="{StaticResource IconFontRegular}" Size="32" Color="{StaticResource Tertiary}" />
                    </Image.Source>
                </Image>
                <Label Grid.Row="3" Grid.Column="1" Text="ComfyUI API Key:" VerticalTextAlignment="Center" Style="{StaticResource LabelHeader}" IsVisible="{Binding IsComfyUiCloudSelected}"/>
                <Entry Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Text="{Binding ComfyUiApiKey}" Placeholder="Required for Cloud" IsPassword="True" HorizontalOptions="Fill" IsVisible="{Binding IsComfyUiCloudSelected}"/>
            </Grid>
        </ScrollView>

        <HorizontalStackLayout Grid.Row="1" Spacing="10" HorizontalOptions="End" Padding="10">
            <Button Text="Cancel" Command="{Binding CancelCommand}" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
            <Button Text="Apply" Command="{Binding ConfirmSettingsCommand}" WidthRequest="100" />
        </HorizontalStackLayout>
    </Grid>

</views:BasePage>
