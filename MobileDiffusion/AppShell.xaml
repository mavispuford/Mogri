<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MobileDiffusion.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MobileDiffusion.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar Shell.TabBarUnselectedColor="{StaticResource IndependenceAccent}">
        <Tab Title="Generation"
             Icon="article"
             Route="MainPageTab">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>
        <Tab Title="Canvas"
             Icon="image"
             Route="MaskPageTab">
            <ShellContent ContentTemplate="{DataTemplate views:MaskPage}" />
        </Tab>
    </TabBar>

    <!--<ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate views:MainPage}"
        Route="MainPage" />-->

</Shell>
