<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MobileDiffusion.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MobileDiffusion.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar Shell.TabBarUnselectedColor="{StaticResource IndependenceAccent}">
        <Tab Title="Generate"
             Route="MainPageTab">
            <Tab.Icon>
                <FontImageSource Glyph="&#xef42;" FontFamily="MaterialIconsRound400" />
            </Tab.Icon>
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>
        <Tab Title="Canvas"
             Route="CanvasPageTab">
            <Tab.Icon>
                <FontImageSource Glyph="&#xe3f4;" FontFamily="MaterialIconsRound400" />
            </Tab.Icon>
            <ShellContent ContentTemplate="{DataTemplate views:CanvasPage}" />
        </Tab>
    </TabBar>

</Shell>
