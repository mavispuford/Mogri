<?xml version="1.0" encoding="utf-8" ?>
<popups:BasePopup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                  xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
                  xmlns:controls="clr-namespace:MobileDiffusion.Controls;assembly=MobileDiffusion"
                  xmlns:mopups="clr-namespace:Mopups.Pages;assembly=Mopups"
                  xmlns:popups="clr-namespace:MobileDiffusion.Views.Popups"
                  x:Class="MobileDiffusion.Views.Popups.LoadingPopup"
                  x:DataType="popups:LoadingPopup"
                  CloseWhenBackgroundIsClicked="False">
    <Border Background="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource IndependenceAccent}}"
            Stroke="Transparent"
            StrokeShape="RoundRectangle 10"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Padding="15"
            WidthRequest="140"
            HeightRequest="140">

        <VerticalStackLayout VerticalOptions="Center"
                             Spacing="8">
            
            <ActivityIndicator IsRunning="True"/>

            <Label 
                x:Name="MessageLabel" 
                HorizontalTextAlignment="Center"
                FontSize="16"/>
            
        </VerticalStackLayout>
        
    </Border>
</popups:BasePopup>
