<?xml version="1.0" encoding="utf-8" ?>
<popups:BasePopup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                  xmlns:popups="clr-namespace:MobileDiffusion.Views.Popups"
                  xmlns:viewModels="clr-namespace:MobileDiffusion.Interfaces.ViewModels"
                  x:Class="MobileDiffusion.Views.Popups.EditMaskItemPopup"
                  x:DataType="viewModels:IEditMaskItemPopupViewModel">

    <Grid>
        <Border HorizontalOptions="Fill"
                 VerticalOptions="Center"
                 StrokeShape="RoundRectangle 10"
                 BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource IndependenceAccent}}"
                 Stroke="Transparent"
                 Margin="30"
                 Padding="15"
                 Opacity="{Binding ContentOpacity}">
            
                <Grid RowSpacing="24"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">

                    <!-- Header -->
                    <Label Grid.Row="0"
                           Text="Edit Mask"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />

                    <!-- Color -->
                    <Grid Grid.Row="1" ColumnDefinitions="*, Auto" ColumnSpacing="16" IsVisible="{Binding IsColorVisible}">
                        <Label Text="Color" 
                               FontAttributes="Bold"
                               VerticalOptions="Center" 
                               FontSize="14"/>
                        <Border Grid.Column="1"
                                HeightRequest="44"
                                WidthRequest="80"   
                                StrokeShape="RoundRectangle 8"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}"
                                BackgroundColor="{Binding DisplayColor}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeColorCommand}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <!-- Opacity -->
                    <VerticalStackLayout Grid.Row="2" Spacing="8" IsVisible="{Binding IsColorVisible}">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Opacity" FontAttributes="Bold" FontSize="14" />
                            <Label Grid.Column="1" Text="{Binding Alpha, StringFormat='{0:P0}'}" FontSize="14" FontAttributes="Bold"/>
                        </Grid>
                        <Slider Minimum="0.01" 
                                Maximum="1.0" 
                                Value="{Binding Alpha}"
                                MinimumTrackColor="{StaticResource Primary}"
                                DragStartedCommand="{Binding DragStartedCommand}"
                                DragCompletedCommand="{Binding DragCompletedCommand}" />
                    </VerticalStackLayout>

                    <!-- Noise -->
                    <VerticalStackLayout Grid.Row="3" Spacing="8" IsVisible="{Binding IsNoiseVisible}">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Noise" FontAttributes="Bold" FontSize="14" />
                            <Label Grid.Column="1" Text="{Binding Noise, StringFormat='{0:P0}'}" FontSize="14" FontAttributes="Bold"/>
                        </Grid>
                        <Slider Minimum="0" 
                                Maximum="1.0" 
                                Value="{Binding Noise}"
                                MinimumTrackColor="{StaticResource Primary}"
                                DragStartedCommand="{Binding DragStartedCommand}"
                                DragCompletedCommand="{Binding DragCompletedCommand}" />
                    </VerticalStackLayout>

                    <!-- Size (Conditional) -->
                    <VerticalStackLayout Grid.Row="4" Spacing="8" IsVisible="{Binding IsBrush}">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Brush Size" FontAttributes="Bold" FontSize="14" />
                            <Label Grid.Column="1" Text="{Binding BrushSize, StringFormat='{0:F0}'}" FontSize="14" FontAttributes="Bold"/>
                        </Grid>
                        <Slider Minimum="1" 
                                Maximum="50"
                                Value="{Binding BrushSize}" 
                                MinimumTrackColor="{StaticResource Primary}"
                                DragStartedCommand="{Binding DragStartedCommand}"
                                DragCompletedCommand="{Binding DragCompletedCommand}" />
                    </VerticalStackLayout>

                    <!-- Done Button -->
                    <Button Grid.Row="5"
                            Text="Done"
                            Command="{Binding CloseCommand}"
                            Margin="0,8,0,0"/>

                </Grid>
         </Border>

         <Border IsVisible="{Binding IsDragging}" 
                 InputTransparent="True"
                 HorizontalOptions="Center" 
                 VerticalOptions="Center" 
                 BackgroundColor="{StaticResource IndependenceAccentFortyPercent}"
                 Stroke="Transparent"
                 StrokeShape="RoundRectangle 10"
                 Padding="20,10">
                 
            <Label Text="{Binding DragInfoText}" 
                   TextColor="White" 
                   FontAttributes="Bold"
                   FontSize="18"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"/>
         </Border>
    </Grid>
</popups:BasePopup>
