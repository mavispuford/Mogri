<?xml version="1.0" encoding="utf-8" ?>
<popups:BasePopup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                  xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
                  xmlns:controls="clr-namespace:MobileDiffusion.Controls;assembly=MobileDiffusion"
                  xmlns:converters="clr-namespace:MobileDiffusion.Converters;assembly=MobileDiffusion"
                  xmlns:viewModels="clr-namespace:MobileDiffusion.Interfaces.ViewModels.Popups"
                  xmlns:popups="clr-namespace:MobileDiffusion.Views.Popups"
                  x:Class="MobileDiffusion.Views.Popups.ResolutionSelectPopup"
                  x:DataType="viewModels:IResolutionSelectPopupViewModel">
    <Border x:Name="MainBorder"
            Background="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource IndependenceAccent}}"
            Stroke="Transparent"
            StrokeShape="RoundRectangle 10"
            HorizontalOptions="Fill"
            VerticalOptions="Center"
            Padding="15">
        <Border.Resources>
            <ResourceDictionary>
                <Style TargetType="Label">
                    <Setter Property="FontSize" Value="16" />
                </Style>

                <Style TargetType="Entry">
                    <Setter Property="FontSize" Value="16" />
                </Style>
            </ResourceDictionary>
        </Border.Resources>
                
        <VerticalStackLayout x:Name="MainLayout"
                             Spacing="10"
                             Padding="20">

            <Grid RowDefinitions="*,auto,*"
                  ColumnDefinitions="*,auto,*"
                  RowSpacing="4"
                  ColumnSpacing="4"
                  WidthRequest="240"
                  HeightRequest="240">
                
                <Border Grid.Row="1"
                        Grid.Column="1"
                        Width="{Binding ExampleRectangleContainerWidth, Mode=OneWayToSource}"
                        Height="{Binding ExampleRectangleContainerHeight, Mode=OneWayToSource}"
                        WidthRequest="200"
                        HeightRequest="200"
                        StrokeThickness="4"
                        Stroke="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray200TwentySixPercent}, Dark={StaticResource Black}}">
                    <Grid WidthRequest="{Binding ExampleRectangleWidth}"
                          HeightRequest="{Binding ExampleRectangleHeight}"
                          HorizontalOptions="Fill"
                          VerticalOptions="Fill">

                        <Rectangle Fill="{StaticResource IndependenceAccent}" HorizontalOptions="Fill" VerticalOptions="Fill" />
                        <Image Aspect="Fill" Source="{Binding InitImageSource}" HorizontalOptions="Fill" VerticalOptions="Fill" />

                    </Grid>
                    
                </Border>

                <!-- Width -->
                
                <Grid Grid.Row="2"
                      Grid.Column="1"
                      RowDefinitions="auto,auto"
                      ColumnSpacing="0"
                      HorizontalOptions="Center">

                    <Rectangle HeightRequest="10" WidthRequest="2" HorizontalOptions="Start" Fill="{StaticResource Gray400}"/>
                    <Rectangle HeightRequest="2" WidthRequest="{Binding ExampleRectangleWidth}" Fill="{StaticResource Gray300}"/>
                    <Rectangle HeightRequest="10" WidthRequest="2" HorizontalOptions="End" Fill="{StaticResource Gray400}"/>

                    <Label Grid.Row="1"
                           HorizontalTextAlignment="Center"
                           Text="{Binding Width}" />

                </Grid>
                
                <!-- Height -->

                <Grid Grid.Row="1"
                      Grid.Column="2"
                      ColumnDefinitions="auto,auto"
                      RowSpacing="0"
                      VerticalOptions="Center">

                    <Rectangle HeightRequest="2" WidthRequest="10" VerticalOptions="Start" Fill="{StaticResource Gray400}"/>
                    <Rectangle HeightRequest="{Binding ExampleRectangleHeight}" WidthRequest="2" Fill="{StaticResource Gray300}"/>
                    <Rectangle HeightRequest="2" WidthRequest="10" VerticalOptions="End" Fill="{StaticResource Gray400}"/>

                    <Label Grid.Column="1"
                           VerticalTextAlignment="Center"
                           Text="{Binding Height}" />

                </Grid>
            </Grid>

            <Grid ColumnDefinitions="*,auto">
                <Label Grid.Column="0" Text="Aspect Ratio:" FontAttributes="Bold" VerticalTextAlignment="Center" />
                <Entry Grid.Column="1" x:Name="AspectRatioEntry" Text="{Binding AspectRatioEntryValue}" VerticalOptions="Center">
                    <Entry.Behaviors>
                        <toolkit:EventToCommandBehavior EventName="Unfocused" Command="{Binding UpdateAllValuesCommand}" />
                    </Entry.Behaviors>
                </Entry>
            </Grid>

            <Grid ColumnDefinitions="*,auto">
                <Label Grid.Column="0" Text="Preserve Aspect Ratio" FontAttributes="Bold" VerticalTextAlignment="Center" />
                <Switch Grid.Column="1" VerticalOptions="Center" IsToggled="{Binding PreserveAspectRatio}" />
            </Grid>

            <Grid ColumnDefinitions="*,auto">
                <Label Grid.Column="0" Text="Width (mult. of 8):" FontAttributes="Bold" VerticalTextAlignment="Center" />
                <Entry Grid.Column="1" x:Name="WidthEntry" Text="{Binding WidthEntryValue}" Keyboard="Numeric" VerticalOptions="Center">
                    <Entry.Behaviors>
                        <toolkit:EventToCommandBehavior EventName="Unfocused" Command="{Binding UpdateAllValuesCommand}" />
                    </Entry.Behaviors>
                </Entry>
            </Grid>
            <Slider Minimum="{Binding MinimumWidthHeight}" Maximum="{Binding MaximumWidthHeight}" Value="{Binding WidthSliderValue}" DragCompletedCommand="{Binding UpdateAllValuesCommand}" />

            <Grid ColumnDefinitions="*,auto">
                <Label Grid.Column="0" Text="Height (mult. of 8):" FontAttributes="Bold" VerticalTextAlignment="Center" />
                <Entry Grid.Column="1" x:Name="HeightEntry" Text="{Binding HeightEntryValue}" Keyboard="Numeric" VerticalOptions="Center">
                    <Entry.Behaviors>
                        <toolkit:EventToCommandBehavior EventName="Unfocused" Command="{Binding UpdateAllValuesCommand}" />
                    </Entry.Behaviors>
                </Entry>
            </Grid>
            <Slider Minimum="{Binding MinimumWidthHeight}" Maximum="{Binding MaximumWidthHeight}" Value="{Binding HeightSliderValue}" DragCompletedCommand="{Binding UpdateAllValuesCommand}" />

            <HorizontalStackLayout HorizontalOptions="End"
                                   Spacing="10">
                <Button Text="Cancel" 
                        HorizontalOptions="Center"
                        Command="{Binding CancelCommand}"/>
                <Button Text="Confirm" 
                        HorizontalOptions="Center"
                        Command="{Binding ConfirmCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Border>
</popups:BasePopup>
