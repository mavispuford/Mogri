<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mctviews="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewModels="clr-namespace:MobileDiffusion.Interfaces.ViewModels"
             xmlns:controls="clr-namespace:MobileDiffusion.Controls;assembly=MobileDiffusion"
             x:Class="MobileDiffusion.Views.MainPage"
             x:DataType="viewModels:IMainPageViewModel"
             Title="Mobile Diffusion">
    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:IsListNotNullOrEmptyConverter x:Key="IsListNotNullOrEmptyConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <Grid x:Name="MainGrid"
          RowDefinitions="auto, auto, auto, auto, *"
          Padding="30"
          RowSpacing="10">

        <Label Grid.Row="0"
                Text="Prompt:" />

        <Editor Grid.Row="1"
                Placeholder="{Binding PlaceholderPrompt}" 
                Text="{Binding Prompt}"
                AutoSize="TextChanges"/>

        <Grid Grid.Row="2"
              ColumnDefinitions="60*,20*,20*"
              ColumnSpacing="10"
              HorizontalOptions="FillAndExpand">
            <Button Grid.Column="0"
                    Text="Create!"
                    Command="{Binding CreateCommand}"/>

            <Button Grid.Column="1"
                    HeightRequest="40"
                    CornerRadius="10"
                    HorizontalOptions="Fill"
                    Command="{Binding ShowRequestSettingsCommand}"
                    BackgroundColor="Transparent">
                <Button.ImageSource>
                    <FontImageSource Glyph="&#xe429;" FontFamily="MaterialIconsRoundRegular" Color="{StaticResource IndependenceAccent}" />
                </Button.ImageSource>
            </Button>
            
            <Button Grid.Column="2"
                    HeightRequest="40"
                    CornerRadius="10"
                    HorizontalOptions="Fill"
                    Command="{Binding ShowImageToImageSettingsCommand}"
                    BackgroundColor="Transparent">
                <Button.ImageSource>
                    <FontImageSource Glyph="&#xe3f4;" FontFamily="MaterialIconsRoundRegular" Color="{StaticResource IndependenceAccent}" />
                </Button.ImageSource>
            </Button>
        </Grid>
            
        <Label Grid.Row="3"
               Text="Result(s):"
               IsVisible="{Binding Results, Converter={StaticResource IsListNotNullOrEmptyConverter}}"/>

        <ScrollView Grid.Row="4" VerticalOptions="FillAndExpand" VerticalScrollBarVisibility="Never" HorizontalScrollBarVisibility="Never">
            <FlexLayout x:Name="ImageLayout"
                        BindableLayout.ItemsSource="{Binding Results}" 
                        HorizontalOptions="CenterAndExpand"
                        VerticalOptions="Start"
                        Wrap="Wrap"
                        JustifyContent="SpaceEvenly"
                        AlignItems="Start"
                        AlignContent="SpaceEvenly">
            <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:IResultItemViewModel">
                        <controls:ImageResultControl Source="{Binding ImageSource}"
                                                     Scale="0"/>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
        </ScrollView>
    </Grid>

</ContentPage>
