<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mctviews="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
             xmlns:viewModels="clr-namespace:MobileDiffusion.Interfaces.ViewModels"
             x:Class="MobileDiffusion.Views.MainPage"
             x:DataType="viewModels:IMainPageViewModel">

    <ScrollView>
        <VerticalStackLayout
            Padding="30"
            Spacing="10"
            x:Name="MainStack">

            <Label Text="Prompt:" />

            <Editor Placeholder="A detailed painting of a kangaroo" 
                    Text="{Binding Prompt}"
                    AutoSize="TextChanges"/>

            <Button Text="Create!"
                    Command="{Binding CreateCommand}"/>

            <Label Text="Result(s):" />

            <FlexLayout BindableLayout.ItemsSource="{Binding ResultImageSources}" HorizontalOptions="Center" Wrap="Wrap">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Image Source="{Binding}" HeightRequest="180" Aspect="AspectFit"/>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
