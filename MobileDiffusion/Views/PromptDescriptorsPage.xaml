<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:models="clr-namespace:MobileDiffusion.Models"
                xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
                xmlns:viewModels="clr-namespace:MobileDiffusion.Interfaces.ViewModels"
                xmlns:views="clr-namespace:MobileDiffusion.Views"
                x:Class="MobileDiffusion.Views.PromptDescriptorsPage"
                x:DataType="viewModels:IPromptDescriptorsPageViewModel"
                Shell.PresentationMode="Animated"
                Shell.NavBarIsVisible="True"
                Shell.TabBarIsVisible="False"
                Title="Prompt Descriptors">
    <views:BasePage.Resources>
        <Style TargetType="Grid">
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="Selected">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor"
                                        Value="{StaticResource PrimaryEightyPercent}" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </views:BasePage.Resources>
    <Grid ColumnDefinitions="auto,*"
          RowDefinitions="auto,*,auto"
          ColumnSpacing="10"
          RowSpacing="10"
          Padding="10"
          Margin="0">

        <Image Grid.Column="0">
            <Image.Source>
                <FontImageSource Glyph="&#xe8b6;" FontFamily="MaterialIconsRoundRegular" Color="{StaticResource IndependenceAccent}" />
            </Image.Source>
        </Image>

        <Border Grid.Row="0"
                Grid.Column="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <Entry x:Name="FilterBar" 
                   HorizontalOptions="FillAndExpand"
                   Margin="10,0">
                <Entry.Behaviors>
                    <toolkit:EventToCommandBehavior
                        EventName="TextChanged"
                        Command="{Binding FilterCommand}"
                        CommandParameter="{Binding Source={x:Reference FilterBar}, Path=Text}"/>
                </Entry.Behaviors>
            </Entry>
        </Border>
        
        <CollectionView x:Name="DescriptorCollectionView"
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        IsGrouped="True"
                        SelectionMode="Multiple"
                        ItemsSource="{Binding DescriptorGroups}"
                        SelectedItems="{Binding SelectedDescriptors}">
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="models:PromptDescriptorGroup">
                    <Label Text="{Binding Name}" 
                           Padding="0,10"
                           FontSize="22"
                           FontAttributes="Bold"/>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:PromptDescriptor">
                    <Grid ColumnDefinitions="*,*"
                          WidthRequest="{Binding Source={x:Reference DescriptorCollectionView}, Path=Width}"
                          Padding="6,10,0,10"
                          HeightRequest="54">
                        <Label Grid.Column="0"
                               Text="{Binding Text}"
                               VerticalOptions="Center"
                               FontSize="16"/>
                        <Label Grid.Column="1"
                               VerticalOptions="Center"
                               Text="{Binding TagsString}"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray200}}"
                               FontSize="12"
                               LineBreakMode="WordWrap" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <HorizontalStackLayout Grid.Row="2" 
                               Grid.ColumnSpan="2"
                               Spacing="10"
                               HorizontalOptions="End" 
                               Padding="10">
            <Button Command="{Binding ResetCommand}" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}">
                <Button.ImageSource>
                    <FontImageSource Glyph="&#xe872;" FontFamily="MaterialIconsRoundRegular" Color="{StaticResource Tertiary}" />
                </Button.ImageSource>
            </Button>
            <Button Text="Cancel" Command="{Binding CancelCommand}" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
            <Button Text="Apply" Command="{Binding ConfirmCommand}" WidthRequest="100" />
        </HorizontalStackLayout>
    </Grid>

</views:BasePage>
