<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:MobileDiffusion.Interfaces.ViewModels"
             x:Class="MobileDiffusion.Controls.PillControl"
             Scale="0"
             x:Name="ThisControl">
    <Border BackgroundColor="{StaticResource Gray300}"
            Stroke="Transparent"
            StrokeShape="RoundRectangle 10"
            Padding="20,6,16,6"
            HeightRequest="50">
        <HorizontalStackLayout Spacing="6">
            <Label Text="{Binding Text, Source={x:Reference ThisControl}}" 
                   TextColor="White" 
                   HorizontalOptions="Start"
                   VerticalTextAlignment="Center" 
                   VerticalOptions="Center"
                   FontAttributes="Bold" />
            <ImageButton ToolTipProperties.Text="{Binding TooltipText, Source={x:Reference ThisControl}}"
                         VerticalOptions="Center"
                         HorizontalOptions="End"
                         Command="{Binding Command, Source={x:Reference ThisControl}}"
                         CommandParameter="{Binding CommandParameter, Source={x:Reference ThisControl}}">
                <ImageButton.Source>
                    <FontImageSource Glyph="&#xe5cd;" FontFamily="MaterialIconsRound400" Size="30" Color="White" />
                </ImageButton.Source>
            </ImageButton>
        </HorizontalStackLayout>
    </Border>
</ContentView>
